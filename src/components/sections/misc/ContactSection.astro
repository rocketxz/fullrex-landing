---
// Import the necessary dependencies.
import AuthBtn from '@components/ui/buttons/AuthBtn.astro';
import ContactIconBlock from '@components/ui/blocks/ContactIconBlock.astro';
import TextInput from '@components/ui/forms/input/TextInput.astro';
import EmailContactInput from '@components/ui/forms/input/EmailContactInput.astro';
import PhoneInput from '@components/ui/forms/input/PhoneInput.astro';
import TextAreaInput from '@components/ui/forms/input/TextAreaInput.astro';
import Icon from '@components/ui/icons/Icon.astro';

// Define the variables that will be used in this component
const title: string = '¿Listo para proteger lo que más importa?';
const subTitle: string =
  'Visítanos en Quitumbe o agenda una inspección técnica hoy mismo. Expertos en seguridad industrial.';
const formTitle: string = 'Envíanos un mensaje';
const formSubTitle: string = 'Te respondemos en 24 horas.';
---

{/* Contact Us */}
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        {
          /* Form for user input with various input fields.>
        {/* Each field utilizes a different input component for the specific type of input (text, email, phone, and textarea)*/
        }
        <form id="contact-form">
          <div class="grid gap-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="hs-firstname-contacts"
                label="Nombre"
                name="hs-firstname-contacts"
              />
              <TextInput
                id="hs-lastname-contacts"
                label="Apellido"
                name="hs-lastname-contacts"
              />
            </div>
            <EmailContactInput id="hs-email-contacts" />
            <PhoneInput id="hs-phone-number" />
            <TextAreaInput
              id="hs-about-contacts"
              label="Mensaje"
              name="hs-about-contacts"
            />
          </div>

          <div class="mt-4 grid">
            <AuthBtn title="Enviar por WhatsApp" />
          </div>

          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>

        <script>
          document.getElementById('contact-form')?.addEventListener('submit', function(e) {
            e.preventDefault();

            const nombre = (document.getElementById('hs-firstname-contacts') as HTMLInputElement)?.value || '';
            const apellido = (document.getElementById('hs-lastname-contacts') as HTMLInputElement)?.value || '';
            const email = (document.getElementById('hs-email-contacts') as HTMLInputElement)?.value || '';
            const telefono = (document.getElementById('hs-phone-number') as HTMLInputElement)?.value || '';
            const mensaje = (document.getElementById('hs-about-contacts') as HTMLTextAreaElement)?.value || '';

            if (!nombre.trim() || !mensaje.trim()) {
              alert('Por favor, completa al menos tu nombre y mensaje.');
              return;
            }

            const texto = `🔒 *Nuevo mensaje desde FULLREX Web*\n\n` +
              `👤 *Nombre:* ${nombre} ${apellido}\n` +
              `📧 *Email:* ${email}\n` +
              `📞 *Teléfono:* ${telefono}\n` +
              `💬 *Mensaje:*\n${mensaje}`;

            const url = `https://wa.me/593961661643?text=${encodeURIComponent(texto)}`;
            window.open(url, '_blank');
          });
        </script>
      </div>

      {
        /*ContactIconBlocks are used to display different methods of contacting*/
      }
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Visítanos"
          content="Estamos en Quitumbe, sur de Quito"
          isAddressVisible={true}
          addressContent="Calle Curaca y S41, Quitumbe"
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Escríbenos"
          content="¿Prefieres escribir? Contáctanos por email"
          isLinkVisible={true}
          linkTitle="fullrex2000@gmail.com"
          linkURL="mailto:fullrex2000@gmail.com"
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Llámanos"
          content="Atención personalizada"
          isLinkVisible={true}
          linkTitle="0961661643 - 0997827958"
          linkURL="tel:+593961661643"
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="WhatsApp"
          content="Chatea con nosotros directamente"
          isLinkVisible={true}
          linkTitle="Escríbenos por WhatsApp"
          linkURL="https://wa.me/593961661643"
          ><Icon name="question" />
        </ContactIconBlock>
      </div>
    </div>

    {/* Google Maps Embed with Actions */}
    <div class="mt-16">
      <div class="mb-6 text-center">
        <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-200 md:text-2xl">
          Nuestra Ubicación en Quitumbe
        </h2>
        <p class="text-neutral-600 dark:text-neutral-400">
          Visítanos en nuestra oficina técnica para asesoría personalizada.
        </p>
      </div>
      
      <div class="group relative overflow-hidden rounded-2xl shadow-xl ring-1 ring-neutral-300 dark:ring-neutral-700">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.697223046714!2d-78.560713!3d-0.3026845!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91d5a30047fde5eb%3A0x9a03ec3241efcb5d!2sFullrex%20Quitumbe!5e0!3m2!1ses-419!2sec!4v1714681200000!5m2!1ses-419!2sec"
          width="100%"
          class="h-72 w-full border-0 transition-all duration-500 md:h-[450px]"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de FULLREX en Quitumbe, Quito"
        ></iframe>
      </div>
      
      <div class="mt-6 flex justify-center">
        <a
          href="https://maps.app.goo.gl/GGuwMwpoJdY5Fzj49"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-x-2 rounded-lg border border-transparent bg-yellow-500 px-6 py-3 text-sm font-bold text-neutral-900 transition-all hover:bg-yellow-400 focus:outline-none dark:focus:outline-none"
        >
          <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          Abrir en Google Maps (GPS)
        </a>
      </div>
    </div>
  </div>
</section>