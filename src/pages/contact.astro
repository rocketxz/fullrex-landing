---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import ContactSection from '@components/sections/misc/ContactSection.astro';
import { SITE } from '@data/constants';

const pageTitle: string = `Contacto FULLREX | Extintores y Cámaras en Quitumbe, Quito`;
const metaDescription =
  'Visítanos en Quitumbe, calle Curaca y S41. Cotización gratuita por WhatsApp ☎ +593 99 782 7958. Extintores, cámaras y alarmas en Quito.';
const ogTitle = 'Contacto FULLREX | Extintores y Cámaras en Quitumbe, Quito';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://fullrexquitumbe.com/contact',
    url: 'https://fullrexquitumbe.com/contact',
    name: 'Contacto | FULLREX',
    description:
      'Contáctanos para servicios de extintores, cámaras de seguridad y alarmas en Quitumbe.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://fullrexquitumbe.com',
      name: 'FULLREX',
      description:
        'Venta de equipos de seguridad en Quitumbe.',
    },
    inLanguage: 'es-EC',
  }}
>
  <ContactSection />
</MainLayout>