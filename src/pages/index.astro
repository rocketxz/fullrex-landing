---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import PricingSection from '@components/sections/pricing/PricingSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import AnnouncementBanner from '@components/ui/banners/AnnouncementBanner.astro';
import ClientsSection from '@components/sections/landing/ClientsSection.astro';
import { partnersData } from '@data/constants';
import heroImage from '@images/hero-image.avif';
import faqs from '@data/faqs.json';
import features from '@data/features.json';
import pricing from '@data/pricing.json';
import featureImage from '@images/features-image.avif';
import construction from '@images/construction-image.avif';
import tools from '@images/automated-tools.avif';
import dashboard from '@images/dashboard-image.avif';

const avatarSrcs: Array<string> = [
  'https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGV ufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80',
  'https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80',
];
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://fullrex-quitumbe.com/#business',
  'name': 'FULLREX — Extintores, Cámaras y Alarmas',
  'image': 'https://fullrex-quitumbe.com/og-image.png',
  'url': 'https://fullrex-quitumbe.com',
  'telephone': '+593961661643',
  'email': 'fullrex2000@gmail.com',
  'description': 'Venta, recarga y mantenimiento de extintores certificados INEN 731. Instalación de cámaras de seguridad Hikvision, Dahua, Ezviz e Imou en Quito.',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': 'Calle Curaca y S41',
    'addressLocality': 'Quito',
    'addressRegion': 'Pichincha',
    'postalCode': '170150',
    'addressCountry': 'EC',
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': -0.3075,
    'longitude': -78.5514,
  },
  'areaServed': [
    { '@type': 'City', 'name': 'Quito' },
    { '@type': 'City', 'name': 'Guayaquil' },
    { '@type': 'City', 'name': 'Cuenca' },
    { '@type': 'Country', 'name': 'Ecuador' },
  ],
  'priceRange': '$$',
  'priceCurrency': 'USD',
  'openingHoursSpecification': [
    {
      '@type': 'OpeningHoursSpecification',
      'dayOfWeek': ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      'opens': '08:00',
      'closes': '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      'dayOfWeek': 'Saturday',
      'opens': '08:00',
      'closes': '14:00',
    },
  ],
  'sameAs': [
    'https://www.facebook.com/fullrex',
    'https://www.tiktok.com/@full.rex.quitumbe',
    'https://wa.me/593961661643',
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': faqs.faqs.map((faq: { question: string; answer: string }) => ({
    '@type': 'Question',
    'name': faq.question,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': faq.answer,
    },
  })),
};
---

<MainLayout
  title="Extintores y Cámaras en Quito | FULLREX — Recarga INEN 731"
  customDescription="Venta, recarga y mantenimiento de extintores certificados INEN 731. Cámaras Hikvision y alarmas en Quito. Cotización gratis ☎ 0961661643"
  customOgTitle="Extintores y Cámaras en Quito | FULLREX — Recarga INEN 731"
  structuredData={localBusinessSchema}
>
  <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle="Visítanos en Quitumbe"
    url="/contact"
  />

  <HeroSection
    title=`VENTA, RECARGA Y MANTENIMIENTO <span class="text-yellow-500 dark:text-yellow-400">PROFESIONAL</span>`
    subTitle="Seguridad para empresas y hogares en el Ecuador. Prevención de incendios y vigilancia avanzada."
    primaryBtn="Ver Servicios"
    primaryBtnURL="/services"
    secondaryBtn="Escríbenos por WhatsApp"
    secondaryBtnURL="https://wa.me/593961661643?text=Hola%20FULLREX%2C%20me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20sobre%20sus%20servicios%20de%20seguridad."
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">100%</span>`
    starCount={5}
    reviews=`Clientes satisfechos en <span class="font-bold">Quito</span>`
    src={heroImage}
    alt="Extintores y sistemas de seguridad FULLREX"
  />

  <ClientsSection
    title="Líderes en Seguridad Industrial"
    subTitle="Empresas que confían en nuestros servicios"
    partners={partnersData}
  />

  <FeaturesGeneral
    title="¿Qué OFRECEMOS?"
    subTitle="Soluciones integrales de seguridad: extintores, cámaras y alarmas para proteger lo que más importa."
    src={featureImage}
    alt="Sistemas de seguridad FULLREX"
    features={features}
  />

  <FeaturesNavs
    title=`NUESTROS <span class="text-yellow-500 dark:text-yellow-400">SERVICIOS</span>`
    tabs={[
      {
        heading: 'Extintores y Prevención',
        content:
          'Venta, recarga y mantenimiento de extintores PQS y CO2. Incluye kits vehiculares con certificación INEN 731.',
        svg: 'sparks',
        src: tools,
        alt: 'Extintores profesionales',
        first: true,
      },
      {
        heading: 'Cámaras y Tecnología',
        content:
          'Sistemas CCTV Hikvision, Dahua, Ezviz, Imou. Acceso remoto desde tu móvil en tiempo real.',
        svg: 'guides',
        src: dashboard,
        alt: 'Cámaras de seguridad',
        second: true,
      },
      {
        heading: 'Alarmas y Detección',
        content:
          'Sistemas de detección de humo y alarmas con mantenimiento electrónico profesional.',
        svg: 'chatBubble',
        src: construction,
        alt: 'Sistemas de alarma',
      },
    ]}
  />

  <TestimonialsSection
    title="Trayectoria y Confianza"
    subTitle="Años de experiencia protegiendo empresas y hogares en Quitumbe."
    testimonials={[
      {
        content:
          'FULLREX nos ha demostrado profesionalismo en cada servicio. Extintores certificados y sistemas de cámaras funcionando perfectamente.',
        author: 'Roxana Martinez',
        role: 'Sector Industrial | Quito',
        avatarSrc:
          'https://images.unsplash.com/photo-1593104547489-5cfb3839a3b5?q=80&w=1453&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
      },
    ]}
    statistics={[
      {
        count: '500+',
        description: 'extintores recargados al año',
      },
      {
        count: '100%',
        description: 'certificación INEN 731',
      },
      {
        count: '24/7',
        description: 'soporte técnico disponible',
      },
      {
        count: 'Quitumbe',
        description: 'cobertura local',
      },
    ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Preguntas<br />frecuentes" faqs={faqs} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <HeroSectionAlt
    title="Contáctanos"
    subTitle="Visítanos en Quitumbe, calle Curaca y S41. Tel: 0961661643 - 0997827958"
    url="https://wa.me/593961661643?text=Hola%20FULLREX%2C%20necesito%20ponerme%20en%20contacto%20con%20ustedes%20para%20una%20asesor%C3%ADa%20de%20seguridad."
  />
</MainLayout>
